# Copy to .env and fill in. Secrets only — non-secret config lives in config/*.yaml.
# Vars are MORNING_BRIEF_<SECTION>__<FIELD>. See CLAUDE.md §5.2 / §5.6 for details.

# Required
MORNING_BRIEF_API__AUTH_TOKEN=                       # python -c "import secrets; print(secrets.token_urlsafe(32))"
MORNING_BRIEF_LLM__ANTHROPIC_API_KEY=
MORNING_BRIEF_DELIVERY__EMAIL__RECIPIENTS=["desk@firm.com"]

# Optional
MORNING_BRIEF_ENVIRONMENT=development                # development | test | production
MORNING_BRIEF_DELIVERY__EMAIL__SMTP_USERNAME=        # if your SMTP relay needs auth
MORNING_BRIEF_DELIVERY__EMAIL__SMTP_PASSWORD=
MORNING_BRIEF_LLM__OPENAI_API_KEY=                   # only for the OpenAI fallback provider
MORNING_BRIEF_DATA__ALPHA_VANTAGE_API_KEY=           # only if data provider = alpha_vantage
# The s3 audit backend uses the runtime IAM role (no secret); bucket/region live in YAML.
