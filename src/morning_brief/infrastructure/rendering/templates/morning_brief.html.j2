<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="supported-color-schemes" content="light dark" />
    <title>{{ subject }}</title>
  </head>
  <!--
    Layout: table-based with inline styles for cross-client reliability (Outlook
    strips <style> blocks and modern CSS). Palette and type are chosen for WCAG AA:
    body text #243b53 on #ffffff is ~11:1; the lightest text (#486581) is ~6:1.
  -->
  <body
    style="margin:0; padding:0; background-color:#eef2f6; -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%;"
  >
    <!-- Preheader: inbox preview text, hidden in the body itself. -->
    <div
      style="display:none; max-height:0; overflow:hidden; mso-hide:all; font-size:1px; line-height:1px; color:#eef2f6; opacity:0;"
    >
      {{ headline }}
    </div>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#eef2f6;">
      <tr>
        <td align="center" style="padding:24px 12px;">
          <table
            role="presentation"
            width="600"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="width:600px; max-width:600px; background-color:#ffffff; border-radius:10px; overflow:hidden; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;"
          >
            <!-- Header: most important first — date + headline -->
            <tr>
              <td style="background-color:#102a43; padding:28px 32px;">
                <div style="color:#9fb3c8; font-size:12px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase;">
                  Fixed Income Morning Brief
                </div>
                <div style="color:#bcccdc; font-size:14px; line-height:1.4; padding-top:4px;">{{ brief_date }}</div>
                <h1 style="margin:14px 0 0; color:#ffffff; font-size:22px; line-height:1.35; font-weight:700;">
                  {{ headline }}
                </h1>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding:4px 32px 0;">
                <h2 style="margin:26px 0 10px; color:#102a43; font-size:16px; line-height:1.3; font-weight:700; border-left:4px solid #2186eb; padding-left:12px;">
                  Key signals
                </h2>
                <ul style="margin:0; padding-left:24px; color:#243b53; font-size:16px; line-height:1.6;">
                  {% for signal in key_signals %}<li style="margin-bottom:6px;">{{ signal }}</li>{% endfor %}
                </ul>

                <h2 style="margin:28px 0 10px; color:#102a43; font-size:16px; line-height:1.3; font-weight:700; border-left:4px solid #2186eb; padding-left:12px; border-top:1px solid #e6ecf2; padding-top:24px;">
                  Yield curve
                </h2>
                <p style="margin:0; color:#243b53; font-size:16px; line-height:1.6;">{{ yield_curve_summary }}</p>

                <h2 style="margin:28px 0 10px; color:#102a43; font-size:16px; line-height:1.3; font-weight:700; border-left:4px solid #2186eb; padding-left:12px; border-top:1px solid #e6ecf2; padding-top:24px;">
                  Macro context
                </h2>
                <p style="margin:0; color:#243b53; font-size:16px; line-height:1.6;">{{ macro_context }}</p>

                <h2 style="margin:28px 0 10px; color:#102a43; font-size:16px; line-height:1.3; font-weight:700; border-left:4px solid #2186eb; padding-left:12px; border-top:1px solid #e6ecf2; padding-top:24px;">
                  Watch today
                </h2>
                <ul style="margin:0; padding-left:24px; color:#243b53; font-size:16px; line-height:1.6;">
                  {% for item in watch_today %}<li style="margin-bottom:6px;">{{ item }}</li>{% endfor %}
                </ul>

                <h2 style="margin:28px 0 10px; color:#102a43; font-size:16px; line-height:1.3; font-weight:700; border-left:4px solid #2186eb; padding-left:12px; border-top:1px solid #e6ecf2; padding-top:24px;">
                  Full brief
                </h2>
                <p style="margin:0; color:#243b53; font-size:16px; line-height:1.6;">{{ full_narrative }}</p>
              </td>
            </tr>

            <!-- Confidence callout -->
            <tr>
              <td style="padding:24px 32px 8px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="background-color:#f0f4f8; border-radius:8px; padding:14px 16px; color:#334e68; font-size:14px; line-height:1.5;">
                      <strong style="color:#102a43;">Confidence: {{ confidence_pct }}%</strong>
                      &mdash; reflects data completeness and analysis certainty.
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding:18px 32px 28px;">
                <div style="border-top:1px solid #d9e2ec; padding-top:16px;">
                  <div style="color:#334e68; font-size:13px; line-height:1.5;">
                    Generated {{ generated_at }} &middot; {{ model_used }}
                  </div>
                  <div style="color:#486581; font-size:12px; line-height:1.5; padding-top:8px;">{{ disclaimer }}</div>
                </div>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
